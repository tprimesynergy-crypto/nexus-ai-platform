# ═══════════════════════════════════════════════════════════════
# NEXUS AI PLATFORM — Configuration Complète
# TANGER NEXUS EXPO & SUMMIT 2026 | Prime Synergy Group
# Copier ce fichier → .env et remplir toutes les valeurs
# ═══════════════════════════════════════════════════════════════

# ── Serveur ───────────────────────────────────────────────────
PORT=3000
NODE_ENV=production
PLATFORM_API_KEY=nexus-secret-key-2026-change-this
WEBHOOK_SECRET=nexus-webhook-secret-change-this
ALLOWED_ORIGINS=https://platform.primesynergy.ma,http://localhost:3000

# ── Projet ────────────────────────────────────────────────────
PROJECT_ID=TNG-NEXUS-2026
ADMIN_EMAIL=t.primesynergy@gmail.com
EVENT_DATE=2026-10-21
EVENT_LOCATION=Tanger, Maroc

# ── Base de Données PostgreSQL ────────────────────────────────
# Option A: Hostinger VPS (recommandé pour production)
PG_HOST=localhost
PG_PORT=5432
PG_DATABASE=tanger_nexus
PG_USER=nexus_user
PG_PASSWORD=CHANGE_THIS_SECURE_PASSWORD
PG_SSL=false

# Option B: Neon.tech (cloud gratuit)
# PG_HOST=ep-xxx.eu-central-1.aws.neon.tech
# PG_DATABASE=neondb
# PG_USER=neondb_owner
# PG_PASSWORD=NEON_PASSWORD
# PG_SSL=true

# ── n8n (Automation Engine) ───────────────────────────────────
N8N_BASE_URL=https://n8n.primesynergy.ma
N8N_API_KEY=your-n8n-api-key-here
NEXUS_PLATFORM_URL=https://platform.primesynergy.ma

